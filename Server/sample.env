DB_USER=OnLiPos
DB_NAME=OnLiPos

# 必須: openssl rand -hex 64 などで生成してください
SECRET_KEY_BASE=

# アクセス元のホスト名（例: myserver.example.com）。未設定でも動作します
HOST_NAME=

# HTTPSを有効にする場合は true にしてください（Server/nginx/ssl/ に証明書が必要）
FORCE_SSL=false

POSTGRES_DOCKER_VERSION=trixie
NGINX_DOCKER_VERSION=alpine-slim

# オプション: Sentry によるエラー監視。設定しなくても動作します
# SENTRY_DSN=
