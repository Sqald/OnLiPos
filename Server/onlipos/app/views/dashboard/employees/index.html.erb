<div class="dashboard-container">
  <%= render 'dashboard/shared/menu' %>

  <section class="dashboard-section">
    <div class="section-header">
      <h2>従業員一覧</h2>
      <%= link_to "従業員を追加", new_dashboard_employee_path, class: "btn-signup" %>
    </div>

    <div class="card card-table">
      <% if @employees.any? %>
        <table class="data-table">
          <thead>
            <tr>
              <th>名前</th>
              <th>所属店舗</th>
              <th>登録日</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @employees.each do |employee| %>
              <tr>
                <td><%= employee.name %></td>
                <td>
                  <% if employee.is_all_stores? %>
                    <span class="status-badge status-active">全店舗</span>
                  <% else %>
                    <%= employee.stores.map(&:name).join(', ').truncate(30) %>
                    <span class="text-sm-muted">(<%= employee.stores.size %>店舗)</span>
                  <% end %>
                </td>
                <td><%= employee.created_at.strftime('%Y/%m/%d') %></td>
                <td>
                  <%= link_to "編集", edit_dashboard_employee_path(employee), class: "btn-sm btn-outline" %>
                  <%= link_to "削除", dashboard_employee_path(employee), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn-sm btn-outline btn-danger-outline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="empty-message">
          <p>従業員がまだ登録されていません。</p>
        </div>
      <% end %>
    </div>
  </section>
</div>