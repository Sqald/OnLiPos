<div class="dashboard-container">
  <%= render 'dashboard/shared/menu' %>

  <div class="dashboard-content card">
    <div class="subtitle d-flex justify-content-between align-items-center mb-3">
      <h2>商品一覧</h2>
      <div class="d-flex gap-2">
        <%= link_to "商品登録", new_dashboard_product_path, class: "btn-signup" %>
      </div>
    </div>

    <div class="card my-4">
      <div class="card-body">
        <h3 class="card-title">CSVで一括登録・更新</h3>
        <p class="text-muted">
          ヘッダー: <strong>code, name, price, description, status, tax_rate</strong> を含むCSVファイルを選択してください。<br>
          statusは <strong>active</strong> または <strong>discontinued</strong>、
          tax_rateは整数（例: 10）を指定します。省略時は10%が適用されます。<br>
          既存コードの商品は上書き更新されます。
        </p>
        <%= form_with(url: import_dashboard_products_path, multipart: true, local: true, class: "d-flex align-items-end") do |form| %>
          <div class="field me-3">
            <%= form.label :file, "CSVファイル", class: "form-label" %>
            <%= form.file_field :file, accept: 'text/csv', class: "form-control" %>
          </div>
          <div class="actions">
            <%= form.submit "インポート", class: "btn-signup" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="filters mb-3">
      <%= form_with url: dashboard_products_path, method: :get, local: true do |f| %>
        <div class="filter-row">
          <div class="filter-item">
            <%= f.label :q, "商品名・コード検索" %><br>
            <%= f.text_field :q, value: params[:q], class: "form-control", placeholder: "商品名またはコード" %>
          </div>
          <div class="filter-item">
            <%= f.label :status, "ステータス" %><br>
            <%= f.select :status,
                  [["すべて", ""], ["有効", "active"], ["廃盤", "discontinued"]],
                  { selected: params[:status] },
                  class: "form-control" %>
          </div>
          <div class="filter-item">
            <br>
            <%= f.submit "検索", class: "btn-signup" %>
          </div>
        </div>
      <% end %>
    </div>

    <table class="data-table">
      <thead>
        <tr>
          <th>商品コード</th>
          <th>商品名</th>
          <th>基本価格</th>
          <th>税率</th>
          <th>ステータス</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td><%= product.code %></td>
            <td><%= product.name %></td>
            <td><%= number_to_currency(product.price) %></td>
            <td><%= product.tax_rate %>%</td>
            <td>
              <span class="status-badge <%= product.active? ? 'status-active' : 'status-inactive' %>">
                <%= product.status_i18n %>
              </span>
            </td>
            <td>
              <%= link_to "編集", edit_dashboard_product_path(product), class: "btn-sm btn-outline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= paginate @products %>
  </div>
</div>
