<div class="dashboard-container">
  <%= render 'dashboard/shared/menu' %>

  <section class="dashboard-section">
    <div class="section-header">
      <h2>店舗管理</h2>
      <%= link_to "店舗を追加", new_dashboard_store_path, class: "btn-signup" %>
    </div>

    <div class="card card-table">
      <% if @stores.any? %>
        <table class="data-table">
          <thead>
            <tr>
              <th>店舗名</th>
              <th>店舗ID</th>
              <th>電話番号</th>
              <th>登録日</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @stores.each do |store| %>
              <tr>
                <td><%= store.name %></td>
                <td><%= store.ascii_name %></td>
                <td><%= store.phone_number.presence || '-' %></td>
                <td><%= store.created_at.strftime('%Y/%m/%d') %></td>
                <td>
                  <%= link_to "編集", edit_dashboard_store_path(store), class: "btn-sm btn-outline" %>
                  <%= link_to "削除", dashboard_store_path(store), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？\n紐付いているPOS端末や在庫情報も削除されます。" }, class: "btn-sm btn-danger-outline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="empty-message">
          <p>店舗がまだ登録されていません。</p>
        </div>
      <% end %>
    </div>
  </section>
</div>