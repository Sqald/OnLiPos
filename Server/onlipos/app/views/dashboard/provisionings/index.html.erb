<div class="dashboard-container">
  <%= render 'dashboard/shared/menu' %>

  <section class="dashboard-section">
    <div class="section-header">
      <h2>端末設定 (プロビジョニング)</h2>
      <%= link_to "設定を追加", new_dashboard_provisioning_path, class: "btn-signup" %>
    </div>

    <div class="card card-table">
      <% if @provisionings.any? %>
        <table class="data-table">
          <thead>
            <tr>
              <th>設定名</th>
              <th>対象店舗</th>
              <th>対象POS</th>
              <th>作成日</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% @provisionings.each do |prov| %>
              <tr>
                <td><%= prov.name %></td>
                <td><%= prov.store.name %></td>
                <td><%= prov.pos_tokens.map(&:name).join(', ').presence || '-' %></td>
                <td><%= prov.created_at.strftime('%Y/%m/%d %H:%M') %></td>
                <td>
                  <%= link_to "削除", dashboard_provisioning_path(prov), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "btn-sm btn-outline btn-danger-outline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="empty-message">
          <p>プロビジョニングデータがありません。</p>
          <p class="text-sm-muted">新しい端末をセットアップするための設定データを作成してください。</p>
        </div>
      <% end %>
    </div>
  </section>
</div>