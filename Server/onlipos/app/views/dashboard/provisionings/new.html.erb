<div class="dashboard-container">
  <%= render 'dashboard/shared/menu' %>

  <section class="dashboard-section">
    <div class="section-header">
      <h2>端末設定の追加</h2>
      <%= link_to "一覧に戻る", dashboard_provisionings_path, class: "btn-outline" %>
    </div>

    <div class="card">
      <%= form_with(model: [:dashboard, @provisioning], local: true, class: "form-vertical") do |f| %>
        <% if @provisioning.errors.any? %>
          <div class="error-messages">
            <ul>
              <% @provisioning.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group">
          <%= f.label :name, "設定名 (管理用)" %>
          <%= f.text_field :name, class: "form-control", placeholder: "例: 本店iPad 1号機用設定" %>
        </div>

        <div class="form-group">
          <%= f.label :store_id, "対象店舗" %>
          <%= f.collection_select :store_id, @stores, :id, :name, { prompt: "店舗を選択" }, { class: "form-control" } %>
        </div>

        <div class="form-group">
          <%= f.label :store_mode, "店舗モード" %>
          <%= f.select :store_mode,
            [['標準', 'standard'], ['飲食店モード', 'restaurant'], ['小売店モード', 'retail']],
            { selected: 'standard' },
            { class: "form-control" } %>
          <p class="form-hint">飲食店モード: 売上登録時に卓番を入力します。小売店モード: 保留・呼び出し機能が使えます。</p>
        </div>

        <div class="form-group">
          <%= f.label :pos_role, "POS ロール" %>
          <%= f.select :pos_role,
            [['標準（スキャン＋会計）', 'standard'], ['ホスト機（待ち受けモードあり）', 'host'], ['クライアント機（転送専用）', 'client']],
            { selected: 'standard' },
            { class: "form-control" } %>
          <p class="form-hint">ホスト機: レジカウンターなど会計を担う端末。クライアント機: フロア持ち歩きタブレットなど、ホストに転送して会計する端末。</p>
        </div>

        <hr class="my-4">
        <h3 class="text-lg font-bold mb-4">ハードウェア設定</h3>

        <div class="form-group">
          <%= f.label :receipt_printer_ip, "レシートプリンター IPアドレス" %>
          <%= f.text_field :receipt_printer_ip, class: "form-control", placeholder: "例: 192.168.1.150" %>
        </div>

        <div class="form-group">
          <%= f.label :drawer_kick_command, "ドロワーキックコマンド" %>
          <%= f.text_field :drawer_kick_command, class: "form-control", value: "27,112,0,50,250", placeholder: "例: 27,112,0,50,250" %>
          <p class="form-hint">ESC/POSコマンドをカンマ区切りの10進数で入力します。</p>
        </div>

        <div class="form-actions">
          <%= f.submit "設定を作成", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </section>
</div>

<style>
  .my-4 { margin-top: 1rem; margin-bottom: 1rem; }
  .mb-4 { margin-bottom: 1rem; }
</style>