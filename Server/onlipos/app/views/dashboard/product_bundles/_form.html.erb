<%= form_with(model: [:dashboard, bundle], local: true, class: "dashboard-form") do |f| %>
  <% if bundle.errors.any? %>
    <div id="error_explanation">
      <ul>
        <% bundle.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :code, "セットコード（バーコード用）" %>
    <%= f.text_field :code, placeholder: "例: SET001" %>
  </div>

  <div class="field">
    <%= f.label :name, "セット名" %>
    <%= f.text_field :name, placeholder: "例: ランチセット" %>
  </div>

  <div class="field">
    <%= f.label :price, "セット価格（税込）" %>
    <%= f.number_field :price, placeholder: "0 の場合は構成商品の合計金額で販売" %>
    <p class="field-hint">※ 0 を設定すると POSでは構成商品の合計金額で会計されます。</p>
  </div>

  <div class="field">
    <%= f.label :status, "ステータス" %>
    <div class="radio-group">
      <%= f.radio_button :status, :active, checked: bundle.active? || bundle.new_record? %>
      <%= f.label :status_active, "有効" %>
      <%= f.radio_button :status, :discontinued %>
      <%= f.label :status_discontinued, "廃盤" %>
    </div>
  </div>

  <h3 class="mt-3">構成商品</h3>
  <p class="field-hint">セットに含める商品と数量を入力してください。</p>

  <table class="data-table" id="bundle-items-table">
    <thead>
      <tr>
        <th>商品</th>
        <th class="text-right" style="width:120px">数量</th>
        <th style="width:60px"></th>
      </tr>
    </thead>
    <tbody id="bundle-items-body">
      <% existing_items = bundle.product_bundle_items.includes(:product) %>
      <% (existing_items.any? ? existing_items : [nil]).each_with_index do |item, idx| %>
        <tr class="bundle-item-row">
          <td>
            <select name="items[][product_id]" class="form-control">
              <option value="">-- 商品を選択 --</option>
              <% @products.each do |p| %>
                <option value="<%= p.id %>" <%= item&.product_id == p.id ? 'selected' : '' %>>
                  <%= p.code %> - <%= p.name %>
                </option>
              <% end %>
            </select>
          </td>
          <td>
            <input type="number" name="items[][quantity]" value="<%= item&.quantity || 1 %>"
                   min="1" class="form-control" style="text-align:right" />
          </td>
          <td>
            <button type="button" class="btn-sm btn-danger remove-item-btn" onclick="this.closest('tr').remove()">削除</button>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <button type="button" class="btn-outline mt-2" id="add-item-btn">+ 商品を追加</button>

  <div class="actions mt-3">
    <%= f.button bundle.new_record? ? "登録する" : "更新する",
          type: "button", class: "btn-signup", onclick: "this.form.submit();" %>
    <%= link_to "キャンセル", dashboard_product_bundles_path, class: "link-cancel" %>
  </div>
<% end %>

<script>
  const products = <%= raw @products.map { |p| { id: p.id, label: "#{p.code} - #{p.name}" } }.to_json %>;

  document.getElementById('add-item-btn').addEventListener('click', function() {
    const tbody = document.getElementById('bundle-items-body');
    const tr = document.createElement('tr');
    tr.className = 'bundle-item-row';

    let options = '<option value="">-- 商品を選択 --</option>';
    products.forEach(p => {
      options += `<option value="${p.id}">${p.label}</option>`;
    });

    tr.innerHTML = `
      <td><select name="items[][product_id]" class="form-control">${options}</select></td>
      <td><input type="number" name="items[][quantity]" value="1" min="1" class="form-control" style="text-align:right" /></td>
      <td><button type="button" class="btn-sm btn-danger" onclick="this.closest('tr').remove()">削除</button></td>
    `;
    tbody.appendChild(tr);
  });
</script>
