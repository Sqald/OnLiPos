<% is_server = @error_info[:category] == :server %>
<% content_for :title, "#{@status_code} #{@error_info[:title]} | OnLiPos" %>

<div class="dashboard-container error-page">
  <div class="card error-card">
    <div class="error-badge <%= 'server' if is_server %>">
      <%= is_server ? "5xx Server Error" : "4xx Client Error" %>
    </div>

    <div class="error-code <%= 'server' if is_server %>"><%= @status_code %></div>
    <div class="error-title"><%= @error_info[:title] %></div>
    <div class="error-desc"><%= @error_info[:ja] %></div>

    <div class="error-actions">
      <%= link_to "ホームへ戻る", root_path, class: "btn-primary" %>
      <a href="javascript:history.back()" class="btn-secondary">前のページへ</a>
    </div>

    <div class="error-footer">
      <a href="/errors">すべてのエラーコード一覧</a>
      &nbsp;·&nbsp;
      <a href="/">OnLiPos</a>
    </div>
  </div>
</div>
